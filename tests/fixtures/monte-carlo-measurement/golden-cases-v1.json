{
  "schemaVersion": "monte-carlo-measurement-golden-v1",
  "status": "approved-target-contract",
  "decisions": [
    { "id": "D-01", "status": "decided", "summary": "Floor-Deckung uses all_dead plus horizon_exhausted over requestedRuns and is null for a batch containing technical_error." },
    { "id": "D-02", "status": "decided", "summary": "Every run ends in exactly one of ruin, all_dead, horizon_exhausted or technical_error, following financial-year chronology." },
    { "id": "D-03", "status": "decided", "summary": "Cut-year share counts completed decumulation years with a finite cut decision and a cut of at least 10 percent." },
    { "id": "D-04", "status": "decided", "summary": "P1 and P2 care distributions are separate; empty conditional distributions are null with sampleSize zero; UI money is real start-price euros." },
    { "id": "D-05", "status": "decided", "summary": "CAPE anchors the first fixed or stationary block and initializes the first Markov regime; IID may draw independently from year two." },
    { "id": "D-06", "status": "decided", "summary": "Consumption-at-Risk is renamed Reale Depotentnahme P10 and uses a run-level real-withdrawal scalar with explicit missingness." },
    { "id": "D-07", "status": "decided", "summary": "V1 fields are canonical; temporary read aliases require deprecation telemetry and expire by Slice 11." },
    { "id": "D-08", "status": "decided", "summary": "Runs default to 10000, require confirmation above 100000 and stop at 1000000; remaining resource bounds are fixed in benchmark-contract-v1.json." },
    { "id": "D-09", "status": "decided", "summary": "Paired compare remains a separate follow-up feature after stable V1 export." },
    { "id": "D-10", "status": "decided", "summary": "Per-run summaries use global run indices and same-runtime reductions are exact across worker and chunk layouts." },
    { "id": "D-11", "status": "decided", "summary": "The pre-hardening snapshot is immutable; later semantic slices create new references and delta ledgers." },
    { "id": "D-12", "status": "decided", "summary": "WorkerJobRunner remains; user cancel terminates active workers without serial fallback and replacement is lazy on the next explicit start." }
  ],
  "cases": [
    {
